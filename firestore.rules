rules_version = '2';

// =============================================================================
// Reglas de seguridad de Firestore para PERC-HNES.
// -----------------------------------------------------------------------------
// Pegalas en: Firebase Console > Firestore Database > Reglas > Publicar.
// (Asegurate de aplicarlas a la base de datos correcta si usas una con nombre;
//  este proyecto usa la base "(default)" salvo que definas
//  NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID.)
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.email == 'hcardoza.admin@perc-hnes.app'
            || request.auth.token.email == 'ffuentes@perc-hnes.app'
            || request.auth.token.email == 'amontes@perc-hnes.app');
    }
    function userProfile() {
      return get(/databases/$(database)/documents/serviceUsers/$(request.auth.uid)).data;
    }
    function isSupervisor() {
      return isSignedIn() && userProfile().role == 'supervisor';
    }
    match /serviceUsers/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
    match /serviceAssignments/{serviceId} {
      allow read, write: if isAdmin();
    }
    match /serviceTabulators/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /sepsTabulators/{docId} {
      allow read: if isSignedIn();
      // Escriben: admin, el dueño del servicio (su propio userId) y el revisor de
      // SEPS Juan Carlos Miranda (jmiranda), que edita/agrega-quita filas y deja
      // comentarios en el SEPS de cualquier servicio.
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid)
        || request.auth.token.email == 'jmiranda@perc-hnes.app';
      allow delete: if isAdmin();
    }
    match /horasTabulators/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /captureCalendar/{periodId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /captureOverrides/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSupervisor()
            && userProfile().supervisorModules.hasAny([request.resource.data.moduleId]));
      allow delete: if isAdmin()
        || (isSupervisor()
            && userProfile().supervisorModules.hasAny([resource.data.moduleId]));
    }
    match /captureRequests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.requestedByUid == request.auth.uid;
      allow update: if isAdmin()
        || (isSupervisor()
            && userProfile().supervisorModules.hasAny([resource.data.moduleId]))
        || (isSignedIn() && resource.data.requestedByUid == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /documentControl/{year} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    // Censo Diario de Pacientes (id = "<periodo>", p.ej. "2026-06").
    // Lo VEN admin y supervisores (NINGUN servicio). Lo EDITAN los admins y
    // Alfonso Montes (amontes@perc-hnes.app). Sin cierre ni restricciones.
    match /censoDiario/{periodId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || userProfile().role == 'admin'
            || userProfile().role == 'supervisor');
      allow write: if isSignedIn()
        && (isAdmin()
            || userProfile().role == 'admin'
            || request.auth.token.email == 'amontes@perc-hnes.app');
    }
    // Insumos de Almacen (id = "<periodo>", p.ej. "2026-06"). Guardado por mes.
    // Lo VEN admin, supervisores y el servicio Almacen. Lo EDITAN esos mismos:
    // admin y Almacen capturan valores; admin y supervisores tambien pueden
    // agregar/quitar filas (se guardan junto con los valores del mes).
    match /insumosAlmacen/{periodId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || userProfile().role == 'supervisor'
            || userProfile().serviceId == 'almacen');
      allow write: if isSignedIn()
        && (isAdmin()
            || userProfile().role == 'supervisor'
            || userProfile().serviceId == 'almacen');
    }
    // Solicitudes de registro de jefes de servicio: cualquiera puede CREAR su
    // solicitud (sin sesion, con validacion de campos y estado "pending"); solo
    // los admins pueden leerlas, aprobarlas o rechazarlas.
    match /signupRequests/{id} {
      allow read: if isAdmin();
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.email is string
        && request.resource.data.serviceId is string
        && request.resource.data.serviceName is string;
      allow update, delete: if isAdmin();
    }
    // Centro de Soporte: cualquier usuario con sesion CREA su ticket (estado
    // "pendiente", con su propio uid y descripcion). Solo admin y supervisores
    // leen la bandeja y cambian el estado. Borrado solo admin.
    match /supportTickets/{ticketId} {
      allow read: if isAdmin() || isSupervisor();
      allow create: if isSignedIn()
        && request.resource.data.status == 'pendiente'
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0;
      allow update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin();
    }
  }
}
