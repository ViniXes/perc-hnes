rules_version = '2';

// =============================================================================
// Reglas de seguridad de Firestore para PERC-HNES.
// -----------------------------------------------------------------------------
// Pegalas en: Firebase Console > Firestore Database > Reglas > Publicar.
// (Asegurate de aplicarlas a la base de datos correcta si usas una con nombre;
//  este proyecto usa la base "(default)" salvo que definas
//  NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID.)
//
// Con el login por "correo deterministico", el inicio de sesion ya NO necesita
// leer Firestore antes de autenticar, por lo que estas reglas pueden quedar
// cerradas: todo requiere sesion iniciada.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // El admin principal se identifica por su correo de acceso fijo.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'hcardoza.admin@perc-hnes.app';
    }

    // Perfil del usuario logueado (rol, modulos de supervisor, etc.).
    function userProfile() {
      return get(/databases/$(database)/documents/serviceUsers/$(request.auth.uid)).data;
    }

    // Supervisores: cuentas con rol "supervisor" en su perfil de serviceUsers.
    function isSupervisor() {
      return isSignedIn() && userProfile().role == 'supervisor';
    }

    // Perfiles: el admin ve/edita todos; cada usuario solo el suyo (uid == doc id).
    match /serviceUsers/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // Asignaciones servicio -> usuario: solo admin.
    match /serviceAssignments/{serviceId} {
      allow read, write: if isAdmin();
    }

    // Tabuladores (id = "<periodo>__<servicio>"). Lectura para cualquier sesion
    // (lo usa el tablero de avance). Escritura: admin o el dueno del registro.
    match /serviceTabulators/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Tabuladores SEPS (id = "<periodo>__<servicio>"). Mismo modelo que los de Horas:
    // lectura con sesion; escritura admin o el dueno del registro.
    match /sepsTabulators/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Tabuladores de Distribucion de Horas (id = "<periodo>__<servicio>").
    match /horasTabulators/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Calendario de captura por periodo: lectura con sesion, escritura admin.
    match /captureCalendar/{periodId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Override de tableros (reabrir/cerrar captura) id = "<periodo>__<servicio>__<modulo>".
    // Lectura para cualquier sesion (el servicio necesita saber si lo reabrieron).
    // Escritura: admin, o un supervisor cuyo perfil incluya ese modulo (Juan Carlos
    // solo SEPS; Flor y Roberto los tres).
    match /captureOverrides/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSupervisor()
            && userProfile().supervisorModules.hasAny([request.resource.data.moduleId]));
      allow delete: if isAdmin()
        || (isSupervisor()
            && userProfile().supervisorModules.hasAny([resource.data.moduleId]));
    }

    // Todo lo demas queda denegado por defecto.
  }
}
