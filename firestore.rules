rules_version = '2';

// =============================================================================
// Reglas de seguridad de Firestore para PERC-HNES.
// -----------------------------------------------------------------------------
// Pegalas en: Firebase Console > Firestore Database > Reglas > Publicar.
// (Asegurate de aplicarlas a la base de datos correcta si usas una con nombre;
//  este proyecto usa la base "(default)" salvo que definas
//  NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID.)
//
// Con el login por "correo deterministico", el inicio de sesion ya NO necesita
// leer Firestore antes de autenticar, por lo que estas reglas pueden quedar
// cerradas: todo requiere sesion iniciada.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // El admin principal se identifica por su correo de acceso fijo.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'hcardoza.admin@perc-hnes.app';
    }

    // Perfiles: el admin ve/edita todos; cada usuario solo el suyo (uid == doc id).
    match /serviceUsers/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // Asignaciones servicio -> usuario: solo admin.
    match /serviceAssignments/{serviceId} {
      allow read, write: if isAdmin();
    }

    // Tabuladores (id = "<periodo>__<servicio>"). Lectura para cualquier sesion
    // (lo usa el tablero de avance). Escritura: admin o el dueno del registro.
    match /serviceTabulators/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Calendario de captura por periodo: lectura con sesion, escritura admin.
    match /captureCalendar/{periodId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Todo lo demas queda denegado por defecto.
  }
}
