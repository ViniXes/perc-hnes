# Variables de entorno requeridas. Copia este archivo a .env.local y completa los
# valores. En produccion, definelas en Vercel (Project Settings -> Environment Variables).
# NO subas .env.local al repositorio (esta en .gitignore).

# --- Firebase (config publica del cliente) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Opcional: base Firestore con nombre (por defecto "(default)").
NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID=

# --- Credenciales de acceso ---
# OJO: al ser app cliente, estas quedan visibles en el bundle del navegador.
# La proteccion real es ROTAR estas claves y mantener el repositorio PRIVADO.
NEXT_PUBLIC_ADMIN_USERNAME=
NEXT_PUBLIC_ADMIN_PASSWORD=
NEXT_PUBLIC_ADMIN_EMAIL=
# Clave temporal con la que se crean los usuarios de servicio y supervisores.
NEXT_PUBLIC_DEFAULT_TEMP_PASSWORD=
